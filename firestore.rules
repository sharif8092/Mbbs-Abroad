rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny all
    match /{document=**} {
      allow read, write: if false;
    }

    // Validation Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Universities
    match /universities/{universityId} {
      allow read: if true; // Publicly readable
      allow write: if isAdmin();
      
      function isValidUniversity(data) {
        return data.name is string && data.name.size() > 0 && data.name.size() <= 200
          && data.country is string && data.country in ['Uzbekistan', 'Kyrgyzstan']
          && data.location is string
          && data.overview is string;
      }
    }

    // Enquiries
    match /enquiries/{enquiryId} {
      allow create: if isValidEnquiry(incoming());
      allow read, update, delete: if isAdmin();

      function isValidEnquiry(data) {
        return data.fullName is string && data.fullName.size() > 0 && data.fullName.size() <= 100
          && data.email is string && data.email.matches('^[^@]+@[^@]+\\.[^@]+$')
          && data.phone is string && data.phone.size() >= 10 && data.phone.size() <= 20
          && data.universityId is string
          && data.status in ['Pending', 'Reviewing', 'Approved', 'Rejected'];
      }
    }

    // Blogs
    match /blogs/{blogId} {
      allow read: if true;
      allow write: if isAdmin();

      function isValidBlog(data) {
        return data.title is string && data.title.size() > 0
          && data.slug is string
          && data.content is string;
      }
    }

    // Gallery
    match /gallery/{imageId} {
      allow read: if true;
      allow write: if isAdmin();

      function isValidGalleryImage(data) {
        return data.url is string && data.url.size() > 0;
      }
    }

    // Admins
    match /admins/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow write: if false; // Only manageable via Firebase Console or special script
    }
  }
}
